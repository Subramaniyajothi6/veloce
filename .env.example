# Copy to .env.local and fill in. .env* is gitignored — never commit real secrets.
# All of these are OPTIONAL: with none set, the site runs on the static dataset
# exactly as before (no database, no admin).

# --- MongoDB (Phase B inventory + bookings) ---------------------------------
# MongoDB Atlas connection string. When set, /models reads from the DB and the
# admin panel + bookings persist. Leave unset to keep using src/data content.
# MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/veloce?retryWrites=true&w=majority"

# --- Admin auth (password + signed cookie) ----------------------------------
# The single owner password for /admin/login.
# ADMIN_PASSWORD="change-me-to-something-long"
# Secret used to sign the session cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SESSION_SECRET="paste-a-long-random-hex-string-here"
